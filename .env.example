# ─── Required: All platforms (Vercel, Render, Docker) ─────────────────────────
# Set these in your deployment platform's dashboard.

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB_NAME=chatbot_rag

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=your_64_char_hex_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Gemini API key (free: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key

# RAG settings
SIMILARITY_THRESHOLD=0.5
TOP_K=4

# ─── Optional ──────────────────────────────────────────────────────────────────
# DEBUG=true
# UPLOAD_DIR=/app/uploads
