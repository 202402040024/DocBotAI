# ─── FastAPI ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get your connection string from https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=chatbot_rag

# ─── JWT Security ─────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── LLM Providers ────────────────────────────────────────────────────────────
# Get your Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Ollama local fallback (optional) — https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# ─── RAG & Embeddings ─────────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
SIMILARITY_THRESHOLD=0.5
TOP_K=4
UPLOAD_DIR=./uploads
