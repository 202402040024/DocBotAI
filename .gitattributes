# Normalize line endings for all text files
* text=auto

# Force LF for source files (works correctly on all OSes)
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.mjs   text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.svg   binary
